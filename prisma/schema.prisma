generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  profile       UserProfile?
  closetItems   ClothingItem[]
  outfits       Outfit[]
  brands        Brand[]
  subscription  Subscription?
  
  @@map("users")
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  topSize       String?  @map("top_size")
  bottomSize    String?  @map("bottom_size")
  shoeSize      String?  @map("shoe_size")
  dressSize     String?  @map("dress_size")
  footWidth     String?  @map("foot_width")
  preferredBrand String? @map("preferred_brand")
  location      String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_profiles")
}

model ClothingItem {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  name          String
  category      String
  brand         String?
  color         String
  colorName     String?  @map("color_name")
  size          String?
  material      String?
  condition     String   @default("good")
  occasion      String?
  season        String?
  imageUrl      String?  @map("image_url")
  estimatedValue Int?    @default(0) @map("estimated_value")
  wearCount     Int      @default(0) @map("wear_count")
  lastWorn      DateTime? @map("last_worn")
  aiTags        String?  @map("ai_tags")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems   OutfitItem[]
  
  @@map("clothing_items")
}

model Outfit {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  name          String
  occasion      String?
  note          String?
  aiMatchScore  Float?   @map("ai_match_score")
  createdAt     DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OutfitItem[]
  
  @@map("outfits")
}

model OutfitItem {
  id        String @id @default(cuid())
  outfitId  String @map("outfit_id")
  itemId    String @map("item_id")
  slot      String
  
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  item ClothingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  @@unique([outfitId, slot])
  @@map("outfit_items")
}

model Brand {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  name      String
  category  String @default("general")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, name])
  @@map("brands")
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  status        String   @default("inactive")
  plan          String   @default("free")
  stripeCustomerId String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
}
